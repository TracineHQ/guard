{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/src/guard/hooks/bash_command_validator.py" },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/src/guard/hooks/git_c_validator.py" },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/src/guard/hooks/commit_message_validator.py" }
        ]
      },
      {
        "matcher": "Read|Bash",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/src/guard/hooks/agent_output_guard.py" }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/src/guard/hooks/credential_check.py" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/src/guard/hooks/protected_files.py" },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/src/guard/hooks/subagent_scope.py" }
        ]
      }
    ]
  }
}
